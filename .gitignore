# Dart tool cache — generated by `dart pub get`, never commit
.dart_tool/

# Package resolution file (legacy, Dart 2 only)
.packages

# Lock file — commit for apps, ignore for libraries
pubspec.lock

# Build artifacts
build/

# Generated API docs
doc/api/

# Test coverage output
coverage/

# Local documentation / planning notes (private)
# docs/plan/ROADMAP.md

# macOS
.DS_Store

# IDE
.idea/
*.iml
.vscode/
